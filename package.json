{
  "name": "sqlguard-mcp",
  "version": "1.1.0",
  "description": "Safety layer MCP server that intercepts SQL queries and enforces guardrails before they reach your database",
  "keywords": [
    "mcp",
    "sql",
    "safety",
    "postgresql",
    "sqlite",
    "ai",
    "claude",
    "cursor",
    "database",
    "guard"
  ],
  "homepage": "https://github.com/sealca/sqlguard-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/sealca/sqlguard-mcp.git"
  },
  "license": "MIT",
  "author": "Sergio Alcaraz <sergio@sealca.com>",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "sqlguard-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^9.4.3",
    "node-sql-parser": "^4.18.0",
    "pg": "^8.11.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^1.2.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
